# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Email Provider Configuration (Recommended for Render & Production)
# Options: "brevo", "web3forms", "formsubmit", "smtp"
EMAIL_PROVIDER="brevo"

# Brevo API Configuration (High reliability HTTPS API delivery)
# API key from Brevo dashboard (API Keys section)
BREVO_API_KEY="xkeysib-..."
# Verified sender email address in Brevo (Senders & IP section)
BREVO_SENDER_EMAIL="admin@yourdomain.com"
# Optional sender name
BREVO_SENDER_NAME="AMPS Portal"

# Web3Forms Configuration (Optional alternative provider)
WEB3FORMS_KEY=

# SMTP Configuration (Optional alternative provider)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Recipient Email for Admission Inquiries
INQUIRY_RECIPIENT_EMAIL=admin@example.com


